generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum LeadStatus {
  NEW
  ENRICHING
  ENRICHED
  ENRICHMENT_FAILED
  READY
  IN_CAMPAIGN
  REPLIED
  OPTED_OUT
  ARCHIVED
}

enum ContactSource {
  MANUAL
  CSV_IMPORT
  API_IMPORT
  ENRICHED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CampaignLeadStatus {
  ACTIVE
  PAUSED
  COMPLETED
  OPTED_OUT
  BOUNCED
}

enum EmailDraftStatus {
  PENDING_GENERATION
  GENERATED
  APPROVED
  EDITED
  REJECTED
  SENT
  FAILED
}

enum EmailMessageStatus {
  SCHEDULED
  SENT
  FAILED
  BOUNCED
}

enum FollowUpStatus {
  PENDING
  SENT
  SKIPPED
  CANCELLED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  DEAD
}

enum TrackingEventType {
  SENT
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  UNSUBSCRIBED
}

enum ActivityType {
  LEAD_CREATED
  LEAD_ENRICHED
  LEAD_ADDED_TO_CAMPAIGN
  DRAFT_GENERATED
  DRAFT_APPROVED
  DRAFT_REJECTED
  EMAIL_SENT
  EMAIL_FAILED
  REPLY_DETECTED
  FOLLOWUP_SCHEDULED
  FOLLOWUP_SENT
  LEAD_OPTED_OUT
  NOTE_ADDED
  LEAD_IMPORTED
  CAMPAIGN_CREATED
  CAMPAIGN_ACTIVATED
  CAMPAIGN_PAUSED
}

enum IntegrationProvider {
  GMAIL
  SENDGRID
  MAILGUN
  POSTMARK
  SES
}

enum EnrichmentProvider {
  WEBSITE_SCRAPE
  CLEARBIT
  APOLLO
  ZOOMINFO
  GOOGLE_PLACES
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  campaigns    Campaign[]
  activityLogs ActivityLog[]
  leadNotes    LeadNote[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IntegrationAccount {
  id           String              @id @default(uuid())
  userId       String
  provider     IntegrationProvider
  accountEmail String?
  accessToken  String?             @db.Text
  refreshToken String?             @db.Text
  expiresAt    DateTime?
  metadata     Json?
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  emailMessages EmailMessage[]

  @@unique([userId, provider])
}

model Company {
  id          String    @id @default(uuid())
  name        String
  website     String?
  domain      String?
  description String?   @db.Text
  industry    String?
  size        String?
  city        String?
  state       String?
  country     String?
  phone       String?
  linkedinUrl String?
  twitterUrl  String?
  logoUrl     String?
  notes       String?   @db.Text
  active      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contacts          Contact[]
  leads             Lead[]
  enrichmentRecords EnrichmentRecord[]
}

model Contact {
  id              String        @id @default(uuid())
  companyId       String?
  firstName       String?
  lastName        String?
  fullName        String?
  title           String?
  email           String?
  phone           String?
  linkedinUrl     String?
  source          ContactSource @default(MANUAL)
  confidenceScore Float?
  notes           String?       @db.Text
  active          Boolean       @default(true)
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company Company? @relation(fields: [companyId], references: [id])
  leads   Lead[]
}

model Lead {
  id            String     @id @default(uuid())
  companyId     String
  contactId     String?
  status        LeadStatus @default(NEW)
  source        String?
  importBatchId String?
  notes         String?    @db.Text
  active        Boolean    @default(true)
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  company               Company                @relation(fields: [companyId], references: [id])
  contact               Contact?               @relation(fields: [contactId], references: [id])
  campaignLeads         CampaignLead[]
  activityLogs          ActivityLog[]
  leadNotes             LeadNote[]
  personalizationRecord PersonalizationRecord?
  emailDrafts           EmailDraft[]
}

model Campaign {
  id              String         @id @default(uuid())
  name            String
  description     String?        @db.Text
  status          CampaignStatus @default(DRAFT)
  autoSend        Boolean        @default(false)
  fromName        String?
  replyTo         String?
  dailySendLimit  Int            @default(50)
  createdByUserId String
  active          Boolean        @default(true)
  deletedAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  createdBy     User               @relation(fields: [createdByUserId], references: [id])
  campaignLeads CampaignLead[]
  sequences     CampaignSequence[]
  activityLogs  ActivityLog[]
}

model CampaignSequence {
  id         String   @id @default(uuid())
  campaignId String
  stepNumber Int
  name       String
  subject    String?
  templateId String?
  delayDays  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign    Campaign       @relation(fields: [campaignId], references: [id])
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  emailDrafts EmailDraft[]

  @@unique([campaignId, stepNumber])
}

model CampaignLead {
  id             String             @id @default(uuid())
  campaignId     String
  leadId         String
  currentStep    Int                @default(1)
  status         CampaignLeadStatus @default(ACTIVE)
  nextFollowUpAt DateTime?
  repliedAt      DateTime?
  optedOutAt     DateTime?
  addedAt        DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  campaign    Campaign           @relation(fields: [campaignId], references: [id])
  lead        Lead               @relation(fields: [leadId], references: [id])
  emailDrafts EmailDraft[]
  followUps   FollowUpSchedule[]

  @@unique([campaignId, leadId])
}

model EmailTemplate {
  id          String    @id @default(uuid())
  name        String
  description String?
  subject     String
  bodyText    String    @db.Text
  bodyHtml    String?   @db.Text
  variables   Json?
  active      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sequences CampaignSequence[]
  drafts    EmailDraft[]
}

model EmailDraft {
  id               String           @id @default(uuid())
  leadId           String
  campaignLeadId   String?
  sequenceId       String?
  templateId       String?
  subject          String
  bodyText         String           @db.Text
  bodyHtml         String?          @db.Text
  status           EmailDraftStatus @default(PENDING_GENERATION)
  aiGenerated      Boolean          @default(false)
  aiModel          String?
  aiPromptSnapshot Json?
  reviewedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  lead         Lead              @relation(fields: [leadId], references: [id])
  campaignLead CampaignLead?     @relation(fields: [campaignLeadId], references: [id])
  sequence     CampaignSequence? @relation(fields: [sequenceId], references: [id])
  template     EmailTemplate?    @relation(fields: [templateId], references: [id])
  emailMessage EmailMessage?
}

model EmailMessage {
  id                   String               @id @default(uuid())
  draftId              String               @unique
  integrationAccountId String?
  provider             IntegrationProvider?
  providerMessageId    String?
  providerThreadId     String?
  toEmail              String
  fromEmail            String
  subject              String
  bodyText             String               @db.Text
  bodyHtml             String?              @db.Text
  status               EmailMessageStatus   @default(SCHEDULED)
  sentAt               DateTime?
  failureReason        String?
  retryCount           Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  draft              EmailDraft          @relation(fields: [draftId], references: [id])
  integrationAccount IntegrationAccount? @relation(fields: [integrationAccountId], references: [id])
  trackingEvents     TrackingEvent[]
  followUps          FollowUpSchedule[]
}

model FollowUpSchedule {
  id              String         @id @default(uuid())
  campaignLeadId  String
  parentMessageId String?
  stepNumber      Int
  scheduledAt     DateTime
  status          FollowUpStatus @default(PENDING)
  sentAt          DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  campaignLead  CampaignLead  @relation(fields: [campaignLeadId], references: [id])
  parentMessage EmailMessage? @relation(fields: [parentMessageId], references: [id])
}

model EnrichmentRecord {
  id           String             @id @default(uuid())
  companyId    String
  provider     EnrichmentProvider
  rawData      Json?
  status       String
  errorMessage String?
  enrichedAt   DateTime           @default(now())
  createdAt    DateTime           @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model PersonalizationRecord {
  id                 String   @id @default(uuid())
  leadId             String   @unique
  companySummary     String?  @db.Text
  painPoints         String[]
  outreachAngle      String?  @db.Text
  icebreaker         String?  @db.Text
  fitSummary         String?  @db.Text
  subjectSuggestions String[]
  dataQualityNotes   String?  @db.Text
  aiModel            String?
  generatedAt        DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])
}

model ActivityLog {
  id          String       @id @default(uuid())
  leadId      String?
  campaignId  String?
  userId      String?
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())

  lead     Lead?     @relation(fields: [leadId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model JobRecord {
  id           String    @id @default(uuid())
  type         String
  status       JobStatus @default(PENDING)
  payload      Json
  result       Json?
  errorMessage String?
  attemptCount Int       @default(0)
  maxAttempts  Int       @default(3)
  scheduledAt  DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  failedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model TrackingEvent {
  id         String            @id @default(uuid())
  messageId  String
  type       TrackingEventType
  metadata   Json?
  occurredAt DateTime          @default(now())

  message EmailMessage @relation(fields: [messageId], references: [id])
}

model ImportBatch {
  id            String    @id @default(uuid())
  fileName      String?
  source        String
  totalRows     Int
  processedRows Int       @default(0)
  failedRows    Int       @default(0)
  status        String    @default("PROCESSING")
  errors        Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
}
